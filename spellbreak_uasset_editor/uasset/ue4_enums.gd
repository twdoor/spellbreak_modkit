## Static lookup table of all UE4/Spellbreak enum values extracted from game assets.
## Used by PropertyRow to show a dropdown instead of a free-text field for Enum properties.
class_name UE4Enums

## Returns the list of known values for an enum type, or [] if unknown.
static func get_values(enum_type: String) -> PackedStringArray:
	var v := _DB.get(enum_type, []) as Array
	var out := PackedStringArray()
	for s in v:
		out.append(s)
	return out

## Returns true if we have any values registered for this enum type.
static func has_enum(enum_type: String) -> bool:
	return _DB.has(enum_type)

